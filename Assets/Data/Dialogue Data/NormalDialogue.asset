--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: ba70d7cd721108349a9a1de1cf758f91, type: 3}
  m_Name: NormalDialogue
  m_EditorClassIdentifier: Assembly-CSharp::NormalDialogueSO
  dialogueInfo:
  - dialogueId: Normal001
    speakerName: "\uD50C\uB808\uC774\uC5B4"
    text: "\uC624\uB298\uBD80\uD130 \uC0C8\uB85C\uC6B4 \uBAA8\uD5D8\uC774 \uC2DC\uC791\uB418\uC5C8\uB2E4. 
      \uC0C8\uB85C\uC6B4 \uACF3, \uC0C8\uB85C\uC6B4 \uD658\uACBD, \uC774 \uBAA8\uB4E0
      \uAC83\uC5D0 \uC801\uC751\uD558\uB294\uB370 \uC2DC\uAC04\uC774 \uC624\uB798\uAC78\uB9AC\uACA0\uC9C0."
    nextDialogueId: Normal002
  - dialogueId: Normal002
    speakerName: "\uD50C\uB808\uC774\uC5B4"
    text: "\uADF8\uB098\uC800\uB098 \uC5EC\uD589\uC744 \uD558\uB824\uBA74 \uBB3C\uC790\uAC00
      \uC911\uC694\uD55C\uB370 \uC5B4\uB290 \uAC78 \uC911\uC810\uC73C\uB85C \uB450\uC5B4\uC57C\uB420\uAE4C?"
    nextDialogueId: ChoiceGroup001
  - dialogueId: Selected001
    speakerName: "\uD50C\uB808\uC774\uC5B4"
    text: "\uC5ED\uC2DC \uBA39\uC744 \uAC8C \uC5C6\uC73C\uBA74 \uC5EC\uD589\uC744
      \uBABB\uD558\uC9C0."
    nextDialogueId: End
  - dialogueId: Selected002
    speakerName: "\uD50C\uB808\uC774\uC5B4"
    text: "\uC5ED\uC2DC \uB3C8\uC774 \uCD5C\uACE0\uC57C!"
    nextDialogueId: End
  - dialogueId: Happy001
    speakerName: "\uC2DC\uC2A4\uD15C"
    text: "\uC624\uB298 \uC544\uCE68 \uC2E0\uAE30\uD55C \uBC84\uC12F\uC744 \uBC1C\uACAC\uD558\uC5EC
      \uBA39\uC5B4\uBD24\uB294\uB370 \uD6A8\uACFC\uAC00 \uC88B\uC740\uB4EF \uD558\uB2E4."
    nextDialogueId: Reward001
  - dialogueId: Happy010
    speakerName: "\uC2DC\uC2A4\uD15C"
    text: "\uC624\uB298 \uBAA8\uD5D8\uD558\uB358 \uC911 \uC804\uC124\uC801\uC778
      \uC601\uC6C5\uC744 \uB9CC\uB098 \uB9CE\uC740 \uAC83\uC744 \uBC30\uC6B8 \uC218
      \uC788\uC5C8\uB2E4."
    nextDialogueId: Reward010
  - dialogueId: Happy020
    speakerName: "\uC2DC\uC2A4\uD15C"
    text: "\uC624\uB298 \uC544\uCE68 \uB124\uC78E\uD074\uB85C\uBC84\uB97C \uBC1C\uACAC\uD574
      \uAE30\uBD84\uC774 \uC88B\uC544\uC84C\uB2E4."
    nextDialogueId: Reward020
  - dialogueId: Upset001
    speakerName: "\uC2DC\uC2A4\uD15C"
    text: "\uC218\uB828\uC744 \uD558\uAE30 \uC704\uD574 \uC5F4\uC2EC\uD788 \uC77D\uC5C8\uB358
      \uCC45\uC774 1000\uB144\uC804 \uBAA8\uD5D8\uAC00\uB97C \uC704\uD55C \uAC83\uC774\uB77C
      \uC544\uBB34 \uC4F8\uBAA8\uAC00 \uC5C6\uB2E4\uB294 \uAC83\uC744 \uC54C\uAC8C
      \uB418\uC5C8\uB2E4."
    nextDialogueId: Loss001
  - dialogueId: Neutral001
    speakerName: "\uC2DC\uC2A4\uD15C"
    text: "\uD070\uC77C \uB0AC\uB2E4. \uC624\uB298 \uB2A6\uC7A0\uC744 \uC7A4\uB2E4.
      \uD53C\uB85C\uB294 \uD480\uB838\uC9C0\uB9CC \uB300\uC2E0 \uD6C8\uB828\uD560
      \uC2DC\uAC04\uC774 \uBD80\uC871\uD560 \uAC83 \uAC19\uB2E4."
    nextDialogueId: Stable001
  - dialogueId: ScenarioDialogue002-01
    speakerName: "\uD50C\uB808\uC774\uC5B4"
    text: "\uB0B4\uC77C\uC774\uBA74 \uBAAC\uC2A4\uD130\uAC00 \uB098\uD0C0\uB098\uB294
      \uC9C0\uC5ED\uC5D0 \uB4E4\uC5B4\uAC00\uAC8C \uB41C\uB2E4. \uC900\uBE44\uB97C
      \uCCA0\uC800\uD788 \uD558\uC790."
    nextDialogueId: End
  - dialogueId: ScenarioDialogue003-01
    speakerName: "\uD50C\uB808\uC774\uC5B4"
    text: "\uAC15\uB825\uD55C \uC801\uC758 \uAE30\uC6B4\uC774 \uB290\uAEF4\uC9C4\uB2E4."
    nextDialogueId: ScenarioDialogue003-02
  - dialogueId: ScenarioDialogue003-02
    speakerName: "\uD50C\uB808\uC774\uC5B4"
    text: "\uD558\uC9C0\uB9CC \uB450\uB835\uC9C0 \uC54A\uB2E4. \uC9C0\uAE08\uAE4C\uC9C0\uC758
      \uB178\uB825\uC774 \uBE5B\uC744 \uBC1C\uD558\uBA74 \uADF8 \uC5B4\uB5A4 \uB09C\uAD00\uC774\uB77C\uB3C4
      \uD574\uCCD0\uB098\uAC08 \uC218 \uC788\uC744 \uAC83\uC774\uB2E4."
    nextDialogueId: ScenarioDialogue003-03
  - dialogueId: ScenarioDialogue003-03
    speakerName: "\uD50C\uB808\uC774\uC5B4"
    text: "\uAC00\uC790. \uB9C8\uC9C0\uB9C9 \uC2F8\uC6C0\uC744 \uD5A5\uD574."
    nextDialogueId: End
  - dialogueId: Select001
    speakerName: "\uC2DC\uC2A4\uD15C"
    text: "\uAE38\uC744 \uAC77\uB2E4 \uC218\uC0C1\uD55C \uC0AC\uB78C\uC744 \uB9CC\uB0AC\uB2E4."
    nextDialogueId: Select002
  - dialogueId: Select002
    speakerName: "\uC218\uC0C1\uD55C \uC0AC\uB78C"
    text: "\uC790\uB124\uB294 \uC774\uC131\uACFC \uAC10\uC131 \uC5B4\uB290 \uAC83\uC744
      \uC911\uC694\uD558\uAC8C \uC0DD\uAC01\uD558\uB098?"
    nextDialogueId: ChoiceGroup002
  - dialogueId: Selected010
    speakerName: "\uC218\uC0C1\uD55C \uC0AC\uB78C"
    text: "\uD6C4\uD6C4 \uADF8\uAC83\uC774 \uC790\uB124\uC758 \uC120\uD0DD\uC778\uAC00..
      \uC798 \uC54C\uACA0\uB124."
    nextDialogueId: End
